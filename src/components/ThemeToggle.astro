---
// ThemeToggle — rendered potentially multiple times (desktop + mobile nav)
// Uses a data attribute + scoped class instead of a global ID to avoid conflicts
import { randomUUID } from 'node:crypto';
const uid = randomUUID().slice(0, 8);
---

<button
  data-theme-toggle={uid}
  aria-label="Toggle light/dark mode"
  class="theme-toggle-btn relative p-2 rounded-md transition-colors duration-150"
  style="color: var(--text-muted);"
  type="button"
>
  <!-- Sun icon (shown in dark mode — clicking switches to light) -->
  <svg
    data-icon-sun={uid}
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style="transition: opacity 0.2s ease;"
  >
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>

  <!-- Moon icon (shown in light mode — clicking switches to dark) -->
  <svg
    data-icon-moon={uid}
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style="position: absolute; top: 8px; left: 8px; transition: opacity 0.2s ease; opacity: 0;"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  function initAllThemeToggles() {
    // Sync all icon pairs to current theme
    function syncIcons() {
      const isLight = document.documentElement.classList.contains('light');
      document.querySelectorAll<SVGElement>('[data-icon-sun]').forEach(el => {
        el.style.opacity = isLight ? '0' : '1';
      });
      document.querySelectorAll<SVGElement>('[data-icon-moon]').forEach(el => {
        el.style.opacity = isLight ? '1' : '0';
      });
    }

    // Attach click handlers to every toggle button (avoid re-attaching)
    document.querySelectorAll<HTMLButtonElement>('.theme-toggle-btn').forEach(btn => {
      if (btn.dataset.themeToggleInit) return;
      btn.dataset.themeToggleInit = '1';
      btn.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncIcons();
      });
    });

    syncIcons();
  }

  initAllThemeToggles();
  document.addEventListener('astro:page-load', initAllThemeToggles);
</script>
