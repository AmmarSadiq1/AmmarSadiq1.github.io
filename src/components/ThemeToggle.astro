---
// ThemeToggle — client:load island
---

<button
  id="theme-toggle"
  aria-label="Toggle light/dark mode"
  class="relative p-2 rounded-md transition-colors duration-150"
  style="color: var(--text-muted);"
  type="button"
>
  <!-- Sun icon (shown in dark mode — clicking switches to light) -->
  <svg
    id="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style="transition: opacity 0.2s ease;"
  >
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>

  <!-- Moon icon (shown in light mode — clicking switches to dark) -->
  <svg
    id="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style="position: absolute; top: 8px; left: 8px; transition: opacity 0.2s ease; opacity: 0;"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');
    if (!btn || !iconSun || !iconMoon) return;

    function updateIcons() {
      const isLight = document.documentElement.classList.contains('light');
      // In light mode: show moon (to switch back to dark)
      // In dark mode: show sun (to switch to light)
      iconSun.style.opacity = isLight ? '0' : '1';
      iconMoon.style.opacity = isLight ? '1' : '0';
    }

    updateIcons();

    btn.addEventListener('click', () => {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      updateIcons();
    });
  }

  // Run on initial load
  initThemeToggle();

  // Also run after Astro page transitions (if any)
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
