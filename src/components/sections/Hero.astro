---
import { meta } from '../../data/portfolio.ts';
---

<section
  id="hero"
  class="min-h-screen flex items-center pt-16"
  aria-labelledby="hero-heading"
>
  <div class="mx-auto max-w-container px-6 md:px-12 py-20 w-full">
    <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-12 md:gap-8">

      <!-- Left: Text Content -->
      <div class="flex-1 max-w-xl">
        <!-- Greeting -->
        <p class="font-mono text-sm tracking-widest uppercase mb-4" style="color: var(--text-muted);">
          Hey, I'm
        </p>

        <!-- Name -->
        <h1
          id="hero-heading"
          class="font-display font-bold"
          style="font-size: clamp(2.8rem, 6vw, 5rem); color: var(--text-primary); line-height: 1.05; letter-spacing: -0.03em;"
        >
          {meta.name}
        </h1>

        <!-- Title -->
        <p
          class="font-mono uppercase tracking-widest text-sm mt-4 mb-6"
          style="color: var(--accent); letter-spacing: 0.12em;"
        >
          {meta.title}
        </p>

        <!-- Tagline -->
        <p class="text-base mb-8 max-w-lg" style="color: var(--text-muted); line-height: 1.7;">
          {meta.tagline}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-3 mb-10">
          <a
            href={meta.resumeUrl}
            download
            class="px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-150 active:scale-95"
            style="background: var(--accent); color: var(--bg-base);"
            aria-label="Download CV"
          >
            Download CV
          </a>
          <a
            href="#contact"
            class="px-5 py-2.5 rounded-lg text-sm font-semibold border transition-all duration-150 active:scale-95"
            style="border-color: var(--accent); color: var(--accent);"
            onmouseover="this.style.background='var(--accent-glow)'"
            onmouseout="this.style.background='transparent'"
          >
            Contact Me ↓
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex items-center gap-1">
          <a
            href={meta.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn profile"
            class="p-2 rounded-md transition-colors duration-150"
            style="color: var(--text-muted);"
            onmouseover="this.style.color='var(--accent)'; this.style.background='var(--bg-subtle)'"
            onmouseout="this.style.color='var(--text-muted)'; this.style.background='transparent'"
          >
            <!-- LinkedIn icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <span class="text-sm px-2" style="color: var(--border);">·</span>

          <a
            href={meta.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub profile"
            class="p-2 rounded-md transition-colors duration-150"
            style="color: var(--text-muted);"
            onmouseover="this.style.color='var(--accent)'; this.style.background='var(--bg-subtle)'"
            onmouseout="this.style.color='var(--text-muted)'; this.style.background='transparent'"
          >
            <!-- GitHub icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>

          <span class="text-sm px-2" style="color: var(--border);">·</span>

          <a
            href={`mailto:${meta.email}`}
            aria-label="Send email"
            class="p-2 rounded-md transition-colors duration-150"
            style="color: var(--text-muted);"
            onmouseover="this.style.color='var(--accent)'; this.style.background='var(--bg-subtle)'"
            onmouseout="this.style.color='var(--text-muted)'; this.style.background='transparent'"
          >
            <!-- Email icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Avatar -->
      <div class="flex-shrink-0">
        <div class="relative">
          <div
            class="w-44 h-44 md:w-52 md:h-52 rounded-full overflow-hidden"
            style="ring: 2px solid var(--accent); outline: 2px solid var(--accent); outline-offset: 4px; background: var(--bg-subtle);"
          >
            <img
              src="/assets/profile.jpg"
              alt="Muhammad Ammar Sadiq — profile photo placeholder"
              width="208"
              height="208"
              loading="eager"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative accent dot -->
          <div
            class="absolute bottom-2 right-2 w-4 h-4 rounded-full"
            style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="flex justify-center mt-16" aria-hidden="true">
      <a href="#about" class="flex flex-col items-center gap-2 transition-opacity duration-200" style="color: var(--text-muted); opacity: 0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">
        <span class="font-mono text-xs tracking-widest uppercase">scroll</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="animation: bounce 2s infinite;"
          aria-hidden="true"
        >
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }
</style>
