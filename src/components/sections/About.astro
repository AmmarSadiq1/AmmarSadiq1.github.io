---
import { about, stats, education } from '../../data/portfolio.ts';
---

<section
  id="about"
  class="py-20 md:py-28"
  aria-labelledby="about-heading"
>
  <div class="mx-auto max-w-container px-6 md:px-12">

    <!-- Section title -->
    <div class="reveal">
      <span class="font-mono text-sm tracking-widest uppercase" style="color: var(--accent);">01 — About</span>
      <h2 id="about-heading" class="font-display text-3xl md:text-4xl font-bold mt-2" style="color: var(--text-primary);">Who I Am</h2>
      <div class="w-12 h-0.5 mt-4 mb-12" style="background: var(--accent);"></div>
    </div>

    <!-- Two-column layout -->
    <div class="flex flex-col md:flex-row gap-12 md:gap-16">

      <!-- Left: Bio text + Education -->
      <div class="flex-1">
        <div class="reveal" style="transition-delay: 100ms;">
          {about.trim().split('\n').filter(p => p.trim()).map(para => (
            <p class="mb-4" style="color: var(--text-primary); font-size: 1.0625rem; line-height: 1.8;">
              {para.trim()}
            </p>
          ))}
        </div>

        <!-- Education -->
        {education.map((edu, i) => (
          <div
            class="reveal mt-8 p-5 rounded-xl border"
            style={`background: var(--bg-surface); border-color: var(--border); transition-delay: ${200 + i * 100}ms;`}
          >
            <div class="flex items-start gap-3">
              <div class="mt-0.5 w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--accent-dim);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);" aria-hidden="true">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              </div>
              <div>
                <p class="font-display font-semibold text-sm" style="color: var(--text-primary);">{edu.degree} in {edu.field}</p>
                <p class="text-sm mt-0.5" style="color: var(--accent);">{edu.institution}</p>
                <div class="flex flex-wrap gap-x-4 gap-y-1 mt-1">
                  <span class="font-mono text-xs" style="color: var(--text-muted);">{edu.period}</span>
                  <span class="font-mono text-xs font-semibold" style="color: var(--accent);">{edu.grade}</span>
                  <span class="font-mono text-xs" style="color: var(--text-muted);">{edu.location}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: Stat cards -->
      <div class="md:w-80 grid grid-cols-2 gap-4 md:gap-5 content-start">
        {stats.map((stat, i) => (
          <article
            class="reveal p-6 rounded-xl border text-center"
            style={`background: var(--bg-surface); border-color: var(--border); transition-delay: ${100 + i * 80}ms;`}
          >
            <p
              class="font-display font-bold"
              style="font-size: clamp(1.6rem, 3vw, 2.2rem); color: var(--accent); line-height: 1.1;"
            >
              {stat.value}
            </p>
            <p class="text-xs mt-1.5" style="color: var(--text-muted); line-height: 1.4;">{stat.label}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
