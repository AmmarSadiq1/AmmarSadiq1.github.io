---
import { experiences } from '../../data/portfolio.ts';
---

<section
  id="experience"
  class="py-20 md:py-28"
  style="background: var(--bg-subtle);"
  aria-labelledby="experience-heading"
>
  <div class="mx-auto max-w-container px-6 md:px-12">

    <!-- Section title -->
    <div class="reveal">
      <span class="font-mono text-sm tracking-widest uppercase" style="color: var(--accent);">02 — Experience</span>
      <h2 id="experience-heading" class="font-display text-3xl md:text-4xl font-bold mt-2" style="color: var(--text-primary);">Where I've Worked</h2>
      <div class="w-12 h-0.5 mt-4 mb-12" style="background: var(--accent);"></div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-4 md:left-8 top-0 bottom-0 w-px"
        style="background: var(--border);"
        aria-hidden="true"
      ></div>

      <div class="flex flex-col gap-10">
        {experiences.map((exp, i) => (
          <article
            class="reveal relative pl-14 md:pl-24"
            style={`transition-delay: ${i * 100}ms;`}
          >
            <!-- Timeline dot -->
            <div
              class="absolute left-0 md:left-4 top-6 w-8 h-8 rounded-full flex items-center justify-center"
              style={`
                background: var(--bg-surface);
                border: 2px solid ${i === 0 ? 'var(--accent)' : 'var(--border)'};
                z-index: 1;
              `}
              aria-hidden="true"
            >
              <div
                class="w-3 h-3 rounded-full"
                style={`background: ${i === 0 ? 'var(--accent)' : 'var(--border)'};`}
              ></div>
            </div>

            <!-- Card -->
            <div
              class="rounded-xl border p-6 md:p-8 transition-all duration-200"
              style="background: var(--bg-surface); border-color: var(--border);"
              onmouseover="this.style.borderColor='var(--accent-dim)'; this.style.transform='translateY(-2px)'"
              onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
            >
              <!-- Header row -->
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <div>
                  <h3 class="font-display font-bold text-lg" style="color: var(--text-primary);">{exp.role}</h3>
                  <div class="flex flex-wrap items-center gap-2 mt-1">
                    <span class="font-semibold text-sm" style="color: var(--accent);">{exp.company}</span>
                    <span class="text-sm" style="color: var(--text-muted);">· {exp.location}</span>
                    {exp.type === 'project' && (
                      <span
                        class="font-mono text-xs px-2 py-0.5 rounded-full"
                        style="background: var(--accent-dim); color: var(--accent);"
                      >
                        Project
                      </span>
                    )}
                  </div>
                </div>
                <span class="font-mono text-xs whitespace-nowrap flex-shrink-0" style="color: var(--text-muted);">{exp.period}</span>
              </div>

              <!-- Description -->
              <p class="text-sm mb-4" style="color: var(--text-muted);">{exp.description}</p>

              <!-- Bullet list -->
              <ul
                class="space-y-2 mb-5 pl-4"
                style="border-left: 2px solid var(--accent-dim);"
              >
                {exp.bullets.map(bullet => (
                  <li class="text-sm" style="color: var(--text-muted); line-height: 1.6;">{bullet}</li>
                ))}
              </ul>

              <!-- Tech tags -->
              <div class="flex flex-wrap gap-2">
                {exp.tech.map(t => (
                  <span
                    class="font-mono text-xs px-3 py-1 rounded-full border"
                    style="background: var(--bg-subtle); color: var(--accent); border-color: var(--border);"
                  >
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
