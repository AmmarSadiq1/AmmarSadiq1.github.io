---
import { meta } from '../../data/portfolio.ts';
---

<section
  id="contact"
  class="py-20 md:py-28"
  aria-labelledby="contact-heading"
>
  <div class="mx-auto max-w-container px-6 md:px-12">

    <!-- Section title -->
    <div class="reveal text-center">
      <span class="font-mono text-sm tracking-widest uppercase" style="color: var(--accent);">05 — Contact</span>
      <h2 id="contact-heading" class="font-display text-3xl md:text-4xl font-bold mt-2" style="color: var(--text-primary);">
        Let's work together.
      </h2>
      <div class="w-12 h-0.5 mt-4 mb-6 mx-auto" style="background: var(--accent);"></div>
      <p class="text-base max-w-lg mx-auto" style="color: var(--text-muted);">
        I'm currently open to new opportunities in embedded systems and firmware engineering.
        Feel free to reach out — I'd love to connect.
      </p>
    </div>

    <!-- Contact cards row -->
    <div class="flex flex-col sm:flex-row gap-5 justify-center mt-12 max-w-2xl mx-auto">

      <!-- Email -->
      <a
        href={`mailto:${meta.email}`}
        class="reveal flex-1 flex items-center gap-4 p-5 rounded-xl border transition-all duration-200"
        style="background: var(--bg-surface); border-color: var(--border); transition-delay: 100ms;"
        onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
        aria-label={`Send email to ${meta.email}`}
      >
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--accent-dim);">
          <!-- Email icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-display font-semibold text-sm" style="color: var(--text-primary);">Email</p>
          <p class="font-mono text-xs truncate mt-0.5" style="color: var(--accent);">{meta.email}</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href={meta.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="reveal flex-1 flex items-center gap-4 p-5 rounded-xl border transition-all duration-200"
        style="background: var(--bg-surface); border-color: var(--border); transition-delay: 200ms;"
        onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
        aria-label="Connect on LinkedIn"
      >
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--accent-dim);">
          <!-- LinkedIn icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color: var(--accent);" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="font-display font-semibold text-sm" style="color: var(--text-primary);">LinkedIn</p>
          <p class="font-mono text-xs mt-0.5" style="color: var(--accent);">Connect with me →</p>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href={meta.github}
        target="_blank"
        rel="noopener noreferrer"
        class="reveal flex-1 flex items-center gap-4 p-5 rounded-xl border transition-all duration-200"
        style="background: var(--bg-surface); border-color: var(--border); transition-delay: 300ms;"
        onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
        aria-label="View GitHub profile"
      >
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--accent-dim);">
          <!-- GitHub icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color: var(--accent);" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <p class="font-display font-semibold text-sm" style="color: var(--text-primary);">GitHub</p>
          <p class="font-mono text-xs mt-0.5" style="color: var(--accent);">View my work →</p>
        </div>
      </a>
    </div>

    <!-- Location note -->
    <p class="text-center text-xs mt-8 reveal" style="color: var(--text-muted); transition-delay: 400ms;">
      📍 Based in {meta.location} · Available for remote collaboration worldwide
    </p>
  </div>
</section>
