---
import { skills } from '../../data/portfolio.ts';
---

<section
  id="skills"
  class="py-20 md:py-28"
  aria-labelledby="skills-heading"
>
  <div class="mx-auto max-w-container px-6 md:px-12">

    <!-- Section title -->
    <div class="reveal">
      <span class="font-mono text-sm tracking-widest uppercase" style="color: var(--accent);">03 — Skills</span>
      <h2 id="skills-heading" class="font-display text-3xl md:text-4xl font-bold mt-2" style="color: var(--text-primary);">Technical Toolkit</h2>
      <div class="w-12 h-0.5 mt-4 mb-12" style="background: var(--accent);"></div>
    </div>

    <!-- Skills grid: 2 col mobile, 4 col desktop -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {skills.map((group, i) => (
        <article
          class="reveal rounded-xl border p-6 transition-all duration-200"
          style={`background: var(--bg-surface); border-color: var(--border); transition-delay: ${i * 60}ms;`}
          onmouseover="this.style.borderColor='var(--accent-dim)'; this.style.transform='translateY(-2px)'"
          onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
        >
          <!-- Card header -->
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xl" aria-hidden="true">{group.icon}</span>
            <h3
              class="font-display font-semibold text-sm leading-tight"
              style="color: var(--accent);"
            >
              {group.category}
            </h3>
          </div>

          <!-- Skill pills -->
          <div class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <span
                class="font-mono text-xs px-3 py-1 rounded-full border"
                style="background: var(--bg-subtle); color: var(--accent); border-color: var(--border);"
              >
                {item}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
