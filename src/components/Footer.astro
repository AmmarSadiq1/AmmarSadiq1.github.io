---
import { meta } from '../data/portfolio.ts';

const year = new Date().getFullYear();
---

<footer
  class="py-8"
  style="border-top: 1px solid var(--border);"
>
  <div
    class="mx-auto max-w-container px-6 md:px-12 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <!-- Copyright -->
    <p class="text-sm" style="color: var(--text-muted);">
      Built with
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors duration-150"
        style="color: var(--accent);"
        aria-label="Astro framework website"
      >
        Astro
      </a>
      · © {year}
      <span style="color: var(--text-primary);">{meta.name}</span>
    </p>

    <!-- Back to top -->
    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="flex items-center gap-2 text-sm font-mono transition-all duration-150 px-3 py-1.5 rounded-lg"
      style="color: var(--text-muted); border: 1px solid var(--border);"
      onmouseover="this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'"
      onmouseout="this.style.color='var(--text-muted)'; this.style.borderColor='var(--border)'"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
      back to top
    </button>
  </div>
</footer>

<script>
  const btn = document.getElementById('back-to-top');
  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
