---
import { meta } from '../data/portfolio.ts';
import ThemeToggle from './ThemeToggle.astro';
import MobileMenu from './MobileMenu.astro';

const navLinks = [
  { href: '#about',          label: 'About' },
  { href: '#experience',     label: 'Experience' },
  { href: '#skills',         label: 'Skills' },
  { href: '#certifications', label: 'Certs' },
  { href: '#contact',        label: 'Contact' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 h-16"
  style="background: rgba(13,19,32,0.85); backdrop-filter: blur(8px); border-bottom: 1px solid var(--border);"
>
  <div class="mx-auto max-w-container px-6 md:px-12 h-full flex items-center justify-between">
    <!-- Logo / Name -->
    <a
      href="#hero"
      class="font-mono text-sm font-semibold tracking-widest uppercase"
      style="color: var(--accent);"
      aria-label="Muhammad Ammar Sadiq — Home"
    >
      {meta.initials}
      <span class="hidden sm:inline" style="color: var(--text-muted); font-weight: 400;"> / Ammar Sadiq</span>
    </a>

    <!-- Desktop Nav -->
    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-3 py-1.5 text-sm font-medium border-b-2 border-transparent transition-colors duration-200"
          style="color: var(--text-muted); font-family: var(--font-body);"
          onmouseover="this.style.color='var(--text-primary)'"
          onmouseout="this.style.color='var(--text-muted)'"
        >
          {link.label}
        </a>
      ))}

      <div class="mx-3 h-5 w-px" style="background: var(--border);"></div>

      <ThemeToggle />

      <a
        href={meta.resumeUrl}
        download
        class="ml-2 px-4 py-1.5 rounded-lg text-sm font-semibold transition-all duration-150 active:scale-95"
        style="background: var(--accent); color: var(--bg-base);"
        aria-label="Download CV"
      >
        Download CV
      </a>
    </nav>

    <!-- Mobile: ThemeToggle + Hamburger -->
    <div class="flex md:hidden items-center gap-2">
      <ThemeToggle />
      <MobileMenu navLinks={navLinks} resumeUrl={meta.resumeUrl} />
    </div>
  </div>
</header>
